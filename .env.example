# FleetCommand environment variables
#
# The app runs fully on mock data with NONE of these set. Add them only when
# you want to switch to a real Supabase backend.

# --- Supabase (client / browser) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-side seeding only — NEVER commit or expose to browser) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
